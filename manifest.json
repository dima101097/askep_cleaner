{
  "manifest_version": 3,
  "name": "Askep Cleaner",
  "version": "2.2",
  "description": "Cleans cache and cookies for askep.net",
  "permissions": [
    "browsingData",
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "host_permissions": [
    "*://*.askep.net/*"
  ]
}
